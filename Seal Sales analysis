-- Extract Sales Data from SAP (Manufacturing Use Case)

SELECT 
    vbak.VBELN AS Sales_Order_Number,
    vbak.ERDAT AS Order_Date,
    vbak.VKORG AS Sales_Organization,
    
    vbap.POSNR AS Item_Number,
    vbap.MATNR AS Material_Code,
    mara.MAKTX AS Material_Description,
    
    vbap.KWMENG AS Order_Quantity,
    vbap.NETWR AS Net_Value,
    
    kna1.KUNNR AS Customer_Code,
    kna1.NAME1 AS Customer_Name,
    kna1.LAND1 AS Country

FROM VBAK vbak

INNER JOIN VBAP vbap 
    ON vbak.VBELN = vbap.VBELN

LEFT JOIN KNA1 kna1 
    ON vbak.KUNNR = kna1.KUNNR

LEFT JOIN MAKT mara 
    ON vbap.MATNR = mara.MATNR

WHERE vbak.ERDAT >= '2023-01-01'
    AND vbak.VKORG = '1000'   -- Example Sales Org

ORDER BY vbak.ERDAT DESC;
